# ============================================================
# MuscleApp — environment variables (template)
# Copy to `.env` and adjust. NEVER commit a `.env` with real secrets.
# ============================================================

# ---- App ----
APP_ENV=development           # development | test | production
APP_NAME=MuscleApp
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
LOG_JSON=false                # true in production (structured logs)

# ---- CORS (comma-separated allowlist) ----
CORS_ORIGINS=http://localhost:5173

# ---- Database (Postgres + pgvector) ----
POSTGRES_USER=muscle
POSTGRES_PASSWORD=muscle_dev_pw
POSTGRES_DB=muscle
POSTGRES_HOST=db
POSTGRES_PORT=5432
# DATABASE_URL is composed from the values above in config.py

# ---- LLM provider (provider-agnostic) ----
LLM_PROVIDER=ollama           # ollama | gemini
LLM_MODEL=llama3.1
# Ollama (dev)
OLLAMA_BASE_URL=http://ollama:11434
# Gemini (deploy) — free tier
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ---- Embeddings (local, free) ----
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ---- Observability (optional) ----
SENTRY_DSN=

# ---- Rate limiting ----
RATE_LIMIT_PER_MINUTE=60

# ---- Frontend (Vite) ----
VITE_API_BASE_URL=http://localhost:8000/api/v1
